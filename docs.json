{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Openclaw 小白养龙虾🦞",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
