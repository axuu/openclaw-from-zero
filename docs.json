     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify"
    }
  },
  "description": "张有菜的 Openclaw 实践记录",
  "seo": {
    "indexing": "all"
